{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
	"settings": {
		"appearanceTools": true,
		"color": {
			"defaultDuotone": false,
			"defaultGradients": false,
			"defaultPalette": false,
			"palette": [
				{
					"color": "#1e3a7b",
					"name": "Bleu primaire",
					"slug": "primary"
				},
				{
					"color": "#f59e0b",
					"name": "Orange secondaire",
					"slug": "secondary"
				},
				{
					"color": "#fbbf24",
					"name": "Jaune accent",
					"slug": "accent"
				},
				{
					"color": "#ffffff",
					"name": "Blanc",
					"slug": "base"
				},
				{
					"color": "#1a1a2e",
					"name": "Contraste",
					"slug": "contrast"
				},
				{
					"color": "#f8fafc",
					"name": "Gris clair",
					"slug": "light-gray"
				},
				{
					"color": "#64748b",
					"name": "Gris",
					"slug": "gray"
				}
			],
			"gradients": [
				{
					"gradient": "linear-gradient(135deg, #1e3a7b 0%, #2d4a8c 100%)",
					"name": "Bleu dégradé",
					"slug": "blue-gradient"
				},
				{
					"gradient": "linear-gradient(135deg, #f59e0b 0%, #fbbf24 100%)",
					"name": "Orange dégradé",
					"slug": "orange-gradient"
				}
			]
		},
		"layout": {
			"contentSize": "800px",
			"wideSize": "1200px"
		},
		"spacing": {
			"defaultSpacingSizes": false,
			"spacingSizes": [
				{
					"name": "Tiny",
					"size": "10px",
					"slug": "20"
				},
				{
					"name": "X-Small",
					"size": "20px",
					"slug": "30"
				},
				{
					"name": "Small",
					"size": "30px",
					"slug": "40"
				},
				{
					"name": "Regular",
					"size": "clamp(30px, 5vw, 50px)",
					"slug": "50"
				},
				{
					"name": "Large",
					"size": "clamp(40px, 7vw, 70px)",
					"slug": "60"
				},
				{
					"name": "X-Large",
					"size": "clamp(50px, 8vw, 100px)",
					"slug": "70"
				}
			],
			"units": ["%", "px", "em", "rem", "vh", "vw"]
		},
		"typography": {
			"defaultFontSizes": false,
			"fluid": true,
			"fontSizes": [
				{
					"fluid": false,
					"name": "Small",
					"size": "0.875rem",
					"slug": "small"
				},
				{
					"fluid": {
						"max": "1.125rem",
						"min": "1rem"
					},
					"name": "Medium",
					"size": "1rem",
					"slug": "medium"
				},
				{
					"fluid": {
						"max": "1.375rem",
						"min": "1.125rem"
					},
					"name": "Large",
					"size": "1.25rem",
					"slug": "large"
				},
				{
					"fluid": {
						"max": "2rem",
						"min": "1.5rem"
					},
					"name": "X-Large",
					"size": "1.75rem",
					"slug": "x-large"
				},
				{
					"fluid": {
						"max": "3rem",
						"min": "2rem"
					},
					"name": "XX-Large",
					"size": "2.5rem",
					"slug": "xx-large"
				}
			],
			"fontFamilies": [
				{
					"fontFamily": "-apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, 'Open Sans', 'Helvetica Neue', sans-serif",
					"name": "System",
					"slug": "system"
				},
				{
					"fontFamily": "Georgia, 'Times New Roman', Times, serif",
					"name": "Serif",
					"slug": "serif"
				}
			]
		},
		"useRootPaddingAwareAlignments": true
	},
	"styles": {
		"color": {
			"background": "var:preset|color|base",
			"text": "var:preset|color|contrast"
		},
		"spacing": {
			"blockGap": "1.5rem",
			"padding": {
				"left": "var:preset|spacing|50",
				"right": "var:preset|spacing|50"
			}
		},
		"typography": {
			"fontFamily": "var:preset|font-family|system",
			"fontSize": "var:preset|font-size|medium",
			"lineHeight": "1.6"
		},
		"elements": {
			"button": {
				"color": {
					"background": "var:preset|color|primary",
					"text": "var:preset|color|base"
				},
				"border": {
					"radius": "6px"
				},
				":hover": {
					"color": {
						"background": "var:preset|color|secondary",
						"text": "var:preset|color|contrast"
					}
				},
				"spacing": {
					"padding": {
						"bottom": "0.875rem",
						"left": "1.5rem",
						"right": "1.5rem",
						"top": "0.875rem"
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "600"
				}
			},
			"h1": {
				"typography": {
					"fontSize": "var:preset|font-size|xx-large",
					"fontWeight": "700",
					"lineHeight": "1.2"
				},
				"color": {
					"text": "var:preset|color|primary"
				}
			},
			"h2": {
				"typography": {
					"fontSize": "var:preset|font-size|x-large",
					"fontWeight": "700",
					"lineHeight": "1.3"
				},
				"color": {
					"text": "var:preset|color|primary"
				}
			},
			"h3": {
				"typography": {
					"fontSize": "var:preset|font-size|large",
					"fontWeight": "600",
					"lineHeight": "1.4"
				},
				"color": {
					"text": "var:preset|color|primary"
				}
			},
			"h4": {
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "600"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var:preset|font-family|system",
					"lineHeight": "1.3"
				}
			},
			"link": {
				"color": {
					"text": "var:preset|color|primary"
				},
				":hover": {
					"color": {
						"text": "var:preset|color|secondary"
					},
					"typography": {
						"textDecoration": "none"
					}
				}
			}
		},
		"blocks": {
			"core/navigation": {
				"typography": {
					"fontSize": "var:preset|font-size|medium",
					"fontWeight": "500"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|base"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|secondary"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/post-title": {
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|primary"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|secondary"
							},
							"typography": {
								"textDecoration": "none"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/site-title": {
				"typography": {
					"fontWeight": "700"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|base"
						},
						":hover": {
							"color": {
								"text": "var:preset|color|secondary"
							}
						},
						"typography": {
							"textDecoration": "none"
						}
					}
				}
			},
			"core/post-date": {
				"color": {
					"text": "var:preset|color|gray"
				},
				"typography": {
					"fontSize": "var:preset|font-size|small"
				}
			},
			"core/post-excerpt": {
				"typography": {
					"fontSize": "var:preset|font-size|medium"
				}
			}
		}
	},
	"templateParts": [
		{
			"area": "header",
			"name": "header",
			"title": "En-tête"
		},
		{
			"area": "footer",
			"name": "footer",
			"title": "Pied de page"
		}
	],
	"customTemplates": [
		{
			"name": "front-page",
			"postTypes": ["page"],
			"title": "Page d'accueil"
		}
	]
}
